---
const categories = [
  {
    title: 'Languages',
    skills: ['JavaScript', 'TypeScript', 'HTML5', 'CSS3', 'Python'],
  },
  {
    title: 'Frameworks & Libraries',
    skills: ['React', 'Astro', 'Next.js', 'Tailwind CSS', 'Framer Motion'],
  },
  {
    title: 'Tools & Others',
    skills: ['Git & GitHub', 'Figma', 'Vercel', 'Vite', 'VS Code'],
  },
];
---

<section id="skills" class="px-16 py-24">
  <h2 class="font-display font-bold text-primary text-3xl flex items-center gap-4 mb-12">
    <span class="font-mono text-accent font-normal text-base">02.</span>
    Skills
    <span class="flex-1 h-px bg-accent/10"></span>
  </h2>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
    {categories.map(cat => (
      <div class="bg-surface border border-accent/10 rounded-lg p-7 hover:border-accent/25 hover:-translate-y-1 transition-all duration-200">
        <h3 class="font-mono text-accent text-xs tracking-widest uppercase mb-5">{cat.title}</h3>
        <ul class="flex flex-col gap-3 list-none">
          {cat.skills.map(s => (
            <li class="font-mono text-muted text-sm flex items-center gap-2 hover:text-primary transition-colors">
              <span class="text-accent text-[10px]">▸</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
