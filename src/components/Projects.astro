---
const projects = [
  {
    title: 'Simple Task Manager',
    description: 'A simple task manager app with drag-and-drop support, built using React, TypeScript, and Tailwind CSS. Users can create, organize, and manage tasks across different stages with a smooth and responsive interface.',
    tech: ['React', 'TypeScript', 'Tailwind'],
    github: 'https://github.com/leumastrycode/simple-task-manager',
    live: 'https://simple-task-manager-vert.vercel.app/',
  },
  {
    title: 'Simple Notes Web',
    description: 'Simple note-taking web app built with React and TypeScript, allowing users to create, edit, and manage notes with a clean and responsive interface.',
    tech: ['React', 'TypeScript', 'Tailwind'],
    github: 'https://github.com/leumastrycode/notes-app',
    live: 'https://notes-app-xi-dun.vercel.app/',
  },
  {
    title: 'Project Three',
    description: 'In Coming',
    tech: ['-', '-', '-'],
    github: 'https://github.com/yourusername/project-three',
    live: 'https://project-three.vercel.app',
  },
  {
    title: 'Project Four',
    description: 'In Coming',
    tech: ['-', '-', '-'],
    github: 'https://github.com/yourusername/project-four',
    live: 'https://project-four.vercel.app',
  },
];
---

<section id="projects" class="px-16 py-24">
  <h2 class="font-display font-bold text-gray-900 dark:text-slate-100 text-3xl flex items-center gap-4 mb-12">
    <span class="font-mono text-mint font-normal text-base">03.</span>
    Projects
    <span class="flex-1 h-px bg-gray-200 dark:bg-mint/10"></span>
  </h2>
 
  <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6">
    {projects.map(project => (
      <div class="bg-gray-50 dark:bg-zinc-900 border border-gray-200 dark:border-zinc-800 rounded-lg p-8 flex flex-col gap-4 hover:border-mint/30 dark:hover:border-mint/30 hover:-translate-y-1.5 transition-all duration-200 group">
 
        <div class="flex items-center justify-between">
          <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="#64ffda" stroke-width="1.5">
            <path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
          </svg>
          <div class="flex gap-4">
            <a href={project.github} target="_blank" rel="noopener" class="text-gray-400 dark:text-slate-500 hover:text-mint transition-colors" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.164 6.839 9.49.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </a>
            <a href={project.live} target="_blank" rel="noopener" class="text-gray-400 dark:text-slate-500 hover:text-mint transition-colors" aria-label="Live">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
        </div>
 
        <h3 class="font-display font-bold text-gray-900 dark:text-slate-100 text-lg group-hover:text-mint transition-colors">
          {project.title}
        </h3>
 
        <p class="font-body text-gray-500 dark:text-slate-400 text-sm leading-relaxed flex-1">
          {project.description}
        </p>
 
        <div class="flex gap-2 flex-wrap mt-2">
          {project.tech.map(t => (
            <span class="font-mono text-[11px] text-mint bg-mint/5 border border-mint/20 px-2.5 py-1 rounded">
              {t}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
